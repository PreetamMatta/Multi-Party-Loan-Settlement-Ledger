# =============================================================================
# Multi-Party Loan & Settlement Ledger — Environment Configuration
# =============================================================================
# Copy this file to backend/.env and fill in real values. Never commit a real
# .env file. Local docker-compose reads variables from backend/.env at runtime.
# =============================================================================

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://ledger_user:ledger_pass@db:5432/ledger
POSTGRES_DB=ledger
POSTGRES_USER=ledger_user
POSTGRES_PASSWORD=ledger_pass

# ----------------------------------------------------------------------------
# Security — HMAC signing for event log tamper-detection
# ----------------------------------------------------------------------------
# Every event row is signed with HMAC-SHA256 using this key. Tampering with
# any row is detectable as long as the key is not also leaked.
# Generate with:
#     python -c "import secrets; print(secrets.token_hex(32))"
# Never commit the real value. Rotation requires re-signing all events
# (a separate batched job — see ADR-0002 once written).
HMAC_SECRET_KEY=

# ----------------------------------------------------------------------------
# Magic-link auth
# ----------------------------------------------------------------------------
# Secret used to sign magic-link tokens emailed to owners.
MAGIC_LINK_SECRET=

# Used to construct magic-link URLs in emails.
APP_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# FX data
# ----------------------------------------------------------------------------
# exchangerate.host API key (or leave blank to use the free tier).
FX_API_KEY=

# ----------------------------------------------------------------------------
# S3-compatible document storage
# ----------------------------------------------------------------------------
# Compatible with AWS S3, Cloudflare R2, or MinIO for local dev.
S3_ENDPOINT_URL=         # Leave blank for AWS S3; set for R2 / MinIO.
S3_BUCKET_NAME=ledger-docs
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# ----------------------------------------------------------------------------
# Nightly export
# ----------------------------------------------------------------------------
# Absolute local path of the cloned private export Git repo.
EXPORT_GIT_REPO_PATH=

# Git remote URL for pushing exports
# (e.g., git@github.com:you/ledger-export.git).
EXPORT_GIT_REMOTE=
